FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=replace-me
JWT_SECRET_KEY=replace-me
DATABASE_URL=sqlite:///instance/polyloop.sqlite
POSTGRES_DATABASE_URL=postgresql+psycopg://polyloop:polyloop@localhost:5432/polyloop
CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost:5173,http://localhost:5174
ACCESS_TOKEN_EXPIRES_MINUTES=30
REFRESH_TOKEN_EXPIRES_DAYS=14
